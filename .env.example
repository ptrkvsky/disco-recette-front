# URL publique du site (sans slash final) — canonique + JSON-LD
PUBLIC_SITE_URL=https://www.exemple.com

# Optionnel : nom affiché dans les données structurées (auteur Person)
# PUBLIC_RECIPE_AUTHOR_NAME=Marie Dupont

# Sanity (lecture publique CDN)
PUBLIC_SANITY_PROJECT_ID=5d2il4tb
PUBLIC_SANITY_DATASET=production
# Optionnel (défaut 2024-01-01 dans le code si absent)
PUBLIC_SANITY_API_VERSION=2024-01-01

# Optionnel : brouillons / contenu privé (ne pas committer de vrai token)
# SANITY_API_READ_TOKEN=
