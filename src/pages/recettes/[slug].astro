---
import Layout from '../../layouts/Layout.astro';
import RecipeDetail from '../../components/recipe-detail.astro';
import { t } from '../../i18n/t';
import { sanityClient } from '../../lib/sanity-client';
import {
	RECIPE_BY_SLUG_QUERY,
	RECIPE_SLUGS_QUERY,
} from '../../lib/groq/recipes';
import type { RecipeDetail as RecipeDetailType, RecipeSlugRow } from '../../types/recipe';
import { SITE_CONFIG_QUERY, type SiteConfigRow } from '../../lib/groq/site-config';
import {
	RECIPE_SHARE_IMAGE_WIDTH,
	urlForRecipeImage,
} from '../../lib/sanity-image';
import { resolveSiteLogoUrl, resolveSiteName } from '../../lib/site-brand';
import { buildRecipeSchemaGraph } from '../../lib/recipe-schema';

export async function getStaticPaths() {
	const rows = await sanityClient.fetch<RecipeSlugRow[]>(RECIPE_SLUGS_QUERY);
	return rows.map(({ slug }) => ({
		params: { slug },
	}));
}

const slug = Astro.params.slug;
if (!slug) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const [recipe, siteConfig] = await Promise.all([
	sanityClient.fetch<RecipeDetailType | null>(RECIPE_BY_SLUG_QUERY, { slug }),
	sanityClient.fetch<SiteConfigRow>(SITE_CONFIG_QUERY).catch((): SiteConfigRow => null),
]);

if (!recipe) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const pageTitle = `${recipe.title} | ${t('recipe.pageTitleSuffix')}`;
const pageDescription = recipe.excerpt ?? undefined;

const siteBase = Astro.site ?? new URL('http://localhost:4321');
const canonical = new URL(`/recettes/${slug}`, siteBase).href;
const imageUrls = [
	urlForRecipeImage(recipe.mainImage, {
		width: RECIPE_SHARE_IMAGE_WIDTH,
		height: 800,
	}),
	urlForRecipeImage(recipe.mainImage, { width: 800, height: 533 }),
].filter((u): u is string => Boolean(u));

const authorFromCms = recipe.author?.name?.trim();
const authorName =
	authorFromCms ||
	(typeof import.meta.env.PUBLIC_RECIPE_AUTHOR_NAME === 'string'
		? import.meta.env.PUBLIC_RECIPE_AUTHOR_NAME.trim()
		: '');

const siteOrigin = siteBase.origin;
const publisherName = resolveSiteName(
	import.meta.env.PUBLIC_SITE_NAME,
	siteConfig?.title ?? null,
	t('layout.defaultTitle'),
);
const publisherLogoUrl = resolveSiteLogoUrl(
	siteOrigin,
	import.meta.env.PUBLIC_SITE_LOGO_URL,
	siteConfig?.logo ?? null,
);

const jsonLd = buildRecipeSchemaGraph({
	recipe,
	canonicalUrl: canonical,
	imageUrls,
	authorName: authorName || undefined,
	publisher: {
		name: publisherName,
		logoUrl: publisherLogoUrl,
	},
});

const primaryOgImage = imageUrls[0];
const ogImageWidth = primaryOgImage ? RECIPE_SHARE_IMAGE_WIDTH : undefined;
const ogImageHeight = primaryOgImage ? 800 : undefined;
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical={canonical}
	jsonLd={jsonLd}
	ogType="article"
	ogTitle={recipe.title}
	ogImage={primaryOgImage}
	ogImageWidth={ogImageWidth}
	ogImageHeight={ogImageHeight}
	twitterCard="summary_large_image"
	articlePublishedTime={recipe.publishedAt ?? undefined}
	articleAuthor={authorName || undefined}
>
	<RecipeDetail recipe={recipe} />
</Layout>
