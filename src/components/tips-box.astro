---
interface Props {
	tips: string;
}

const { tips } = Astro.props;
---

<aside class="rounded-xl border-l-4 border-accent bg-accent/5 px-5 py-5 md:px-7" aria-labelledby="tips-heading">
	<h2 id="tips-heading" class="m-0 mb-3 flex items-center gap-2 text-lg font-semibold">
		<svg class="h-5 w-5 text-accent-on-surface" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.663 17h4.673M12 3v1m6.364 1.636-.707.707M21 12h-1M4 12H3m3.343-5.657-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 12 18.469c-.84 0-1.642-.376-2.13-.99l-.548-.547Z"/></svg>
		Conseils du chef
	</h2>
	<p class="m-0 whitespace-pre-wrap leading-relaxed text-foreground/85 italic">
		{tips}
	</p>
</aside>
