---
import { labelDifficulty } from '../lib/recipe-labels';
import type { RecipeDifficulty } from '../types/recipe';

interface Props {
	prepTimeMin?: number | null;
	cookTimeMin?: number | null;
	baseServings: number;
	difficulty?: RecipeDifficulty | null;
}

const { prepTimeMin, cookTimeMin, baseServings, difficulty } = Astro.props;
const totalMin =
	(prepTimeMin ?? 0) + (cookTimeMin ?? 0) || null;
---

<div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
	{prepTimeMin != null ? (
		<div class="flex flex-col items-center gap-1 rounded-xl bg-white/70 px-3 py-3 text-center">
			<svg class="h-5 w-5 text-accent-on-surface" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
			<span class="text-xs font-medium uppercase tracking-wide text-muted">Préparation</span>
			<span class="text-base font-semibold">{prepTimeMin} min</span>
		</div>
	) : null}

	{cookTimeMin != null ? (
		<div class="flex flex-col items-center gap-1 rounded-xl bg-white/70 px-3 py-3 text-center">
			<svg class="h-5 w-5 text-accent-on-surface" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4m6.9 1.1-2.8 2.8M22 12h-4M19.8 18.9l-2.8-2.8M12 22v-4M4.2 18.9l2.8-2.8M2 12h4M4.2 5.1l2.8 2.8"/></svg>
			<span class="text-xs font-medium uppercase tracking-wide text-muted">Cuisson</span>
			<span class="text-base font-semibold">{cookTimeMin} min</span>
		</div>
	) : null}

	<div class="flex flex-col items-center gap-1 rounded-xl bg-white/70 px-3 py-3 text-center">
		<svg class="h-5 w-5 text-accent-on-surface" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
		<span class="text-xs font-medium uppercase tracking-wide text-muted">Portions</span>
		<span class="text-base font-semibold">{baseServings}</span>
	</div>

	{difficulty ? (
		<div class="flex flex-col items-center gap-1 rounded-xl bg-white/70 px-3 py-3 text-center">
			<svg class="h-5 w-5 text-accent-on-surface" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
			<span class="text-xs font-medium uppercase tracking-wide text-muted">Difficulté</span>
			<span class="text-base font-semibold">{labelDifficulty(difficulty)}</span>
		</div>
	) : null}

	{totalMin != null && totalMin > 0 ? (
		<div class="col-span-2 flex flex-col items-center gap-1 rounded-xl bg-accent/10 px-3 py-3 text-center sm:col-span-4">
			<span class="text-xs font-medium uppercase tracking-wide text-accent-on-surface">Temps total</span>
			<span class="text-lg font-bold text-accent-on-surface">{totalMin} min</span>
		</div>
	) : null}
</div>
