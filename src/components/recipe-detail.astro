---
import type { RecipeDetail } from '../types/recipe';
import HeroRecipe from './hero-recipe.astro';
import AuthorCard from './author-card.astro';
import RecipeIntro from './recipe-intro.astro';
import RecipeBox from './recipe-box.astro';
import TipsBox from './tips-box.astro';
import NutritionGrid from './nutrition-grid.astro';
import { portableTextToHtml } from '../lib/portable-text-html';
import { urlForRecipeImage } from '../lib/sanity-image';

interface Props {
	recipe: RecipeDetail;
}

const { recipe } = Astro.props;
const author = recipe.author;
const avatarUrl = urlForRecipeImage(author?.image ?? null, { width: 112, height: 112 });
const rawBioHtml = author != null ? portableTextToHtml(author.bio ?? null) : '';
const authorBioHtml = rawBioHtml.trim() ? rawBioHtml : undefined;
const authorSlug = author?.slug?.trim();
const authorProfileHref =
	authorSlug != null && authorSlug.length > 0
		? `/auteurs/${authorSlug}`
		: author?._id
			? `/auteurs/by-id/${author._id}`
			: undefined;
---

<main>
	<article>
		<HeroRecipe recipe={recipe} />

		<div class="mx-auto max-w-3xl space-y-8 px-4 pb-16 print:space-y-3 print:pb-4 print:pt-0">
			<AuthorCard
				name={author?.name}
				avatarUrl={avatarUrl}
				authorFromSanity={author != null}
				bioHtml={authorBioHtml}
				nameHref={authorProfileHref}
				social={author?.social}
			/>

			<RecipeIntro introduction={recipe.introduction} />

			<RecipeBox recipe={recipe} />

			{recipe.tips ? (
				<div class="print:hidden">
					<TipsBox tips={recipe.tips} />
				</div>
			) : null}

			{recipe.nutrition ? (
				<div class="print:hidden">
					<NutritionGrid nutrition={recipe.nutrition} />
				</div>
			) : null}
		</div>
	</article>
</main>
