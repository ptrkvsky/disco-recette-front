---
import { urlForRecipeImage } from '../lib/sanity-image';
import { labelDifficulty } from '../lib/recipe-labels';
import type { RecipeListItem } from '../types/recipe';

interface Props {
	recipe: RecipeListItem;
}

const { recipe } = Astro.props;
const href = `/recettes/${recipe.slug}`;
const imgUrl = urlForRecipeImage(recipe.mainImage, {
	width: 560,
	height: 320,
});
const alt =
	recipe.mainImage?.alt?.trim() ||
	`Illustration de la recette « ${recipe.title} »`;
const totalMin =
	(recipe.prepTimeMin ?? 0) + (recipe.cookTimeMin ?? 0) || null;
---

<article
	class="group flex h-full flex-col overflow-hidden rounded-xl bg-surface shadow-sm transition-[box-shadow,transform] duration-200 hover:-translate-y-0.5 hover:shadow-lg"
>
	<a
		class="flex h-full flex-col text-inherit no-underline"
		href={href}
	>
		{
			imgUrl ? (
				<img
					class="aspect-560/320 w-full object-cover"
					src={imgUrl}
					alt={alt}
					width="560"
					height="320"
					loading="lazy"
					decoding="async"
				/>
			) : (
				<div
					class="aspect-560/320 w-full bg-linear-to-br from-[#e8e4df] to-[#d4cfc7]"
					aria-hidden="true"
				/>
			)
		}
		<div class="flex flex-1 flex-col gap-2 px-[1.1rem] pb-[1.15rem] pt-4">
			<h2 class="m-0 text-lg font-semibold leading-snug">{recipe.title}</h2>
			{
				recipe.excerpt ? (
					<p class="m-0 flex-1 text-sm leading-snug text-muted">
						{recipe.excerpt}
					</p>
				) : null
			}
			<div class="mt-1 flex flex-wrap gap-1.5">
				{
					totalMin != null && totalMin > 0 ? (
						<span class="rounded-full bg-badge px-2.5 py-0.5 text-[0.78rem] text-badge-fg">
							{totalMin} min
						</span>
					) : null
				}
				{
					recipe.difficulty ? (
						<span class="rounded-full bg-badge px-2.5 py-0.5 text-[0.78rem] text-badge-fg">
							{labelDifficulty(recipe.difficulty)}
						</span>
					) : null
				}
			</div>
		</div>
	</a>
</article>
