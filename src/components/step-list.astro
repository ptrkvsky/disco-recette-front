---
import type { RecipeStep } from '../types/recipe';

interface Props {
	steps: RecipeStep[];
}

const { steps } = Astro.props;
---

<ol class="m-0 list-none space-y-0 p-0">
	{steps.map((step, i) => (
		<li class={`flex gap-4 py-5 ${i < steps.length - 1 ? 'border-b border-border/50' : ''}`}>
			<div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent text-sm font-bold text-accent-fg" aria-hidden="true">
				{i + 1}
			</div>
			<div class="min-w-0 flex-1 pt-0.5">
				{step.title ? (
					<p class="m-0 mb-2 text-base font-semibold">{step.title}</p>
				) : null}
				<p class="m-0 whitespace-pre-wrap leading-relaxed text-foreground/90">
					{step.instruction}
				</p>
			</div>
		</li>
	))}
</ol>
