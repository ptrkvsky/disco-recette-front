---
import type { RecipeStep } from '../types/recipe';

interface Props {
	steps: RecipeStep[];
}

const { steps } = Astro.props;
---

<ol class="m-0 list-none space-y-0 p-0">
	{steps.map((step, i) => (
		<li
			class={`break-inside-avoid flex gap-3 py-5 print:gap-2 print:py-2 ${i < steps.length - 1 ? 'border-b border-border/50 print:border-neutral-300' : ''}`}
		>
			<div
				class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent text-sm font-bold text-accent-fg print:h-6 print:w-6 print:text-xs"
				aria-hidden="true"
			>
				{i + 1}
			</div>
			<div class="min-w-0 flex-1 pt-0.5 print:pt-0">
				{step.title ? (
					<p class="m-0 mb-2 text-base font-semibold print:mb-0.5 print:text-sm">{step.title}</p>
				) : null}
				<p class="m-0 whitespace-pre-wrap text-base leading-relaxed text-foreground/90 print:text-sm print:leading-snug">
					{step.instruction}
				</p>
			</div>
		</li>
	))}
</ol>
