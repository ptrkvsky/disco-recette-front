---
import '../styles/global.css';
import { getActiveLocale } from '../i18n/locale';
import { t } from '../i18n/t';
import { sanityClient } from '../lib/sanity-client';
import {
	SITE_CONFIG_THEME_QUERY,
	type SiteConfigThemeRow,
} from '../lib/groq/site-config';
import { siteThemeToRootStyleBlock } from '../lib/site-theme-css';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	jsonLd?: unknown;
}

const locale = getActiveLocale();
const { title = t('layout.defaultTitle'), description, canonical, jsonLd } = Astro.props;

let siteThemeCss: string | null = null;
try {
	const row = await sanityClient.fetch<SiteConfigThemeRow>(SITE_CONFIG_THEME_QUERY);
	siteThemeCss = siteThemeToRootStyleBlock(row?.theme ?? null);
} catch {
	siteThemeCss = null;
}
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{description ? <meta name="description" content={description} /> : null}
		{canonical ? <link rel="canonical" href={canonical} /> : null}
		<title>{title}</title>
		{jsonLd != null ? (
			<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		) : null}
	</head>
	<body>
		<slot />
		{canonical ? (
			<p
				class="mx-auto hidden max-w-3xl px-4 pt-6 text-center text-[0.7rem] leading-snug text-neutral-600 print:block break-all"
				aria-hidden="true"
			>
				{canonical}
			</p>
		) : null}
		{siteThemeCss ? <style is:inline set:html={siteThemeCss} /> : null}
	</body>
</html>
