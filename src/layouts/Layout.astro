---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	jsonLd?: unknown;
}

const { title = 'Recettes', description, canonical, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{description ? <meta name="description" content={description} /> : null}
		{canonical ? <link rel="canonical" href={canonical} /> : null}
		<title>{title}</title>
		{jsonLd != null ? (
			<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		) : null}
	</head>
	<body>
		<slot />
		{canonical ? (
			<p
				class="mx-auto hidden max-w-3xl px-4 pt-6 text-center text-[0.7rem] leading-snug text-neutral-600 print:block break-all"
				aria-hidden="true"
			>
				{canonical}
			</p>
		) : null}
	</body>
</html>
